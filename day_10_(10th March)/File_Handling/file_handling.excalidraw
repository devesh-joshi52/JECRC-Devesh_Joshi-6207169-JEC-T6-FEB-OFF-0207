      "link": null,
      "locked": false,
      "text": "read mode:\n    1. only read (r),\n    2. read with write (r+)\n    3. read binary (rb)\n    4. read & bread binary (rb+)",
      "fontSize": 19.61603080077053,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "read mode:\n    1. only read (r),\n    2. read with write (r+)\n    3. read binary (rb)\n    4. read & bread binary (rb+)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
