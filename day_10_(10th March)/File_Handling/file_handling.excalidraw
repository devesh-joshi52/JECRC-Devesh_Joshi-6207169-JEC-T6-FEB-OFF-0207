      "updated": 1773134006117,
      "link": null,
      "locked": false,
      "text": "NOTE:\n    1. In this, if the file is not present, it wil create one then perform write operation\n    2. If the file is already present, then it will override the prev data with the new one.",
      "fontSize": 20,
      "fontFamily": 5,
