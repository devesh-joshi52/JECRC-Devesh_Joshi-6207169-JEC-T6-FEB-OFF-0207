      "updated": 1773133999216,
      "link": null,
      "locked": false,
      "text": "** For write operation,\n    1. write(str_data) Single line of data.\n    2.writelines([ line1, line2, ....., linen ]): Multi line data.\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "** For write operation,\n    1. write(str_data) Single line of data.\n    2.writelines([ line1, line2, ....., linen ]): Multi line data.\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
