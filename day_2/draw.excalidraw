      "boundElements": [],
      "updated": 1771840321740,
      "link": null,
      "locked": false,
      "text": "it is a type of single value or individual data type which have \nexactly two values. One is \"True\" and another one is \"False\".",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "it is a type of single value or individual data type which have \nexactly two values. One is \"True\" and another one is \"False\".",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "i5fLlF6SRtdodBWgYb0Xd",
      "type": "text",
      "x": 3346.218055845177,
      "y": 9302.811473737193,
      "width": 154,
      "height": 50,
      "angle": 0,
