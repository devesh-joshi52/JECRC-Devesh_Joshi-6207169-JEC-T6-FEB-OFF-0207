      "text": "-- Numeric:\n    1. int,\n    2. float,\n    3. complex,\n-- Bool:\n    1. False,\n    2. True\n-- NoneType:\n    1. None",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
